() {" line17="        direction = -1" line18="        maze = []" line19="        for (let j = 0; j &lt; 8; j++) {" line20="            mazeRow = []" line21="            for (let k = 0; k &lt; 10; k++) {" line22="                mazeRow.push(0)" line23="            }" line24="            maze.push(mazeRow)" line25="        }" line26="        maze[7][5] = 1" line27="        scene.setTileAt(scene.getTile(5, 7), 12)" line28="        curCol = 5" line29="        curRow = 6" line30="        directions = [-1, 1]" line31="        maze[6][5] = 1" line32="        lastCElls = [&quot;r&quot;, &quot;r&quot;]" line33="        while (curRow &gt;= 1) {" line34="            scene.setTileAt(scene.getTile(curCol, curRow), 12)" line35="            if (randint(0, 2) == 0) {" line36="                curRow = curRow - 1" line37="                maze[curRow][curCol] = 1" line38="                removedCell = lastCElls.shift()" line39="                lastCElls.push(&quot;r&quot;)" line40="            } else {" line41="                if (lastCElls.indexOf(&quot;c&quot;) == -1) {" line42="                    direction = directions[randint(0, 1)]" line43="                    lastDirection = direction" line44="                } else {" line45="                    direction = lastDirection" line46="                }" line47="                if (curCol + direction &gt;= 0 &amp;&amp; curCol + direction &lt;= 9) {" line48="                    curCol = curCol + direction" line49="                    maze[curRow][curCol] = 1" line50="                    removedCell = lastCElls.shift()" line51="                    lastCElls.push(&quot;c&quot;)" line52="                }" line53="            }" line54="        }" line55="        scene.setTileAt(scene.getTile(curCol, 0), 12)" line56="        maze[0][curCol] = 1" line57="        myTile = scene.getTile(5, 7)" line58="        myTile.place(mySprite)" line59="        myPlayerCol = 5" line60="        myPlayerRow = 7" line61="    }" line62="    export functio